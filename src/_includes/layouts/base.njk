<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}" />

  <link rel="icon" type="image/png" href="{{ '/images/circle_logo-1-.png' | url }}" />
  <link rel="apple-touch-icon" href="{{ '/images/circle_logo-1-.png' | url }}" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:description" content="{{ description }}" />
  <meta property="og:image" content="{{ '/images/circle_logo_transparent-1-.png' | url }}" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ title }}" />
  <meta name="twitter:description" content="{{ description }}" />
  <meta name="twitter:image" content="{{ '/images/circle_logo_transparent-1-.png' | url }}" />

  <link rel="stylesheet" href="{{ '/styles/base.css' | url }}" />
  <link rel="stylesheet" href="{{ '/styles/components.css' | url }}" />
  <link rel="stylesheet" href="{{ '/styles/theme.css' | url }}" />
</head>
<body>

  {% include "partials/header.njk" %}

  <main id="top">
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  {# ─── Accent A/B toggle ───────────────────────────────────
     Temporary floating button to compare sage (#9CC4BC) vs
     teal (#8ED4C6) for the accent color. State persists in
     localStorage. Remove this <script> block (and the
     body[data-accent="teal"] rule in theme.css) once we settle
     on a final accent. #}
  <script>
    (function () {
      'use strict';
      var KEY = 'hep4rep-accent';
      var ACCENTS = ['sage', 'teal', 'deep'];
      var current = 'sage';
      try {
        var saved = localStorage.getItem(KEY);
        if (ACCENTS.indexOf(saved) !== -1) current = saved;
      } catch (e) {}
      document.body.setAttribute('data-accent', current);

      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'accent-toggle';
      btn.textContent = 'Accent: ' + current;
      btn.setAttribute('aria-label', 'Cycle accent color through sage, teal, and deep');

      btn.addEventListener('click', function () {
        var idx = ACCENTS.indexOf(current);
        current = ACCENTS[(idx + 1) % ACCENTS.length];
        document.body.setAttribute('data-accent', current);
        btn.textContent = 'Accent: ' + current;
        try { localStorage.setItem(KEY, current); } catch (e) {}
      });

      document.body.appendChild(btn);
    })();
  </script>

</body>
</html>
