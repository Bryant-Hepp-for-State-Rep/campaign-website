<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}" />
  <link rel="stylesheet" href="{{ '/styles/base.css' | url }}" />
  <link rel="stylesheet" href="{{ '/styles/components.css' | url }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,900;1,700&family=Archivo+Black&family=Anton&family=Bungee&family=Bricolage+Grotesque:wght@800&family=Big+Shoulders+Display:wght@900&family=Bowlby+One&family=Roboto+Slab:wght@900&family=Fraunces:ital,wght@0,400;0,900;1,400&family=Funnel+Display:wght@900&display=swap" rel="stylesheet" />
  <script src="{{ '/wordmark-font.js' | url }}" defer></script>
  <script src="{{ '/logo-system.js' | url }}" defer></script>
</head>
<body>

  <div id="logo-system-bar"></div>

  {% include "partials/header.njk" %}

  <main id="top">
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

</body>
</html>
