<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-logo" href="{{ '/' | url }}" aria-label="Bryant Hepp for State Rep — home">
      <span class="site-logo__line">Bryant Hepp</span>
      <span class="site-logo__connector">for</span>
      <span class="site-logo__line">State Rep</span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      {%- set focusPolicy = policies[site.in_focus_policy] %}
      {%- for link in nav.links %}
      <a href="{{ link.target | url }}">{{ link.label }}</a>
      {%- if loop.first and focusPolicy %}
      <a href="{{ '/#in-focus' | url }}">{{ focusPolicy.nav_label or focusPolicy.label }}</a>
      {%- endif %}
      {%- endfor %}
      <a class="button button--small button--primary" href="{{ site.primary_cta.target | url }}">{{ site.primary_cta.label }}</a>
    </nav>
  </div>
</header>
