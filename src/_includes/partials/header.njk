<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-logo" href="{{ '/' | url }}" aria-label="Bryant Hepp for State Rep — home">
      <img src="{{ '/images/dark-over-light-logo.png' | url }}" alt="Bryant Hepp for State Rep" />
    </a>
    <nav class="site-nav" aria-label="Primary">
      {%- for link in nav.links %}
      <a href="{{ link.target | url }}">{{ link.label }}</a>
      {%- endfor %}
      <a class="button button--small button--primary" href="{{ site.primary_cta.target | url }}">{{ site.primary_cta.label }}</a>
    </nav>
  </div>
</header>
