<footer class="site-footer">
  <div class="container">
    <div class="site-footer__top">
      <a class="site-logo" href="#top" aria-label="Bryant Hepp for State Rep — back to top">
        <img src="{{ '/images/circle_logo-1-.png' | url }}" alt="Bryant Hepp for State Rep" />
      </a>
      <nav class="site-footer__socials" aria-label="Social media">
        {%- for social in site.socials %}
        <a href="{{ social.url }}">{{ social.platform }}</a>
        {%- endfor %}
      </nav>
      <p class="site-footer__contact"><a href="mailto:{{ site.contact_email }}">{{ site.contact_email }}</a></p>
    </div>
    <div class="site-footer__legal">
      <span>{{ site.committee_disclaimer }}</span>
      <span>© 2026</span>
    </div>
  </div>
</footer>
