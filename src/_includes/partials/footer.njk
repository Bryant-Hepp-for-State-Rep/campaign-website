{%- from "partials/social-icon.njk" import socialIcon -%}
<footer class="site-footer">
  <div class="container">
    <div class="site-footer__top">
      <a class="site-logo" href="#top" aria-label="Bryant Hepp for State Rep — back to top">
        <span class="site-logo__line">Bryant Hepp</span>
        <span class="site-logo__line"><span class="site-logo__connector">for</span> State Rep</span>
      </a>
      <nav class="site-footer__socials" aria-label="Social media">
        {%- for social in site.socials %}
        <a href="{{ social.url }}" aria-label="{{ social.platform }}" rel="me noopener" target="_blank">
          {{ socialIcon(social.platform) }}
        </a>
        {%- endfor %}
      </nav>
      <p class="site-footer__contact"><a href="mailto:{{ site.contact_email }}">{{ site.contact_email }}</a></p>
    </div>
    <div class="site-footer__legal">
      <span>{{ site.committee_disclaimer }}</span>
      <span>© 2026</span>
    </div>
  </div>
</footer>
