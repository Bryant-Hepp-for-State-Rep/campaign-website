---
layout: layouts/base.njk
title: Bryant Hepp for State Rep — Home
description: Bryant Hepp, Democrat for Michigan State House District 9.
permalink: /index.html
---

<section class="hero">
  <div class="container">
    <div class="hero__grid">
      <div>
        <span class="hero__office">{{ home.hero.eyebrow }}</span>
        <h1 class="hero__name">{{ home.hero.name }}</h1>
        <p class="hero__district">{{ home.hero.district_line }}</p>
        <p class="hero__tagline">{{ home.hero.tagline | mdInline | safe }}</p>
        <p class="hero__subhead">{{ home.hero.subhead | mdInline | safe }}</p>
        <div class="hero__ctas">
          <a class="button button--primary" href="{{ home.hero.primary_cta.target | url }}">{{ home.hero.primary_cta.label }}</a>
          {% if home.hero.secondary_cta and home.hero.secondary_cta.label %}
          <a class="button button--secondary" href="{{ home.hero.secondary_cta.target | url }}">{{ home.hero.secondary_cta.label }}</a>
          {% endif %}
        </div>
      </div>
      {% if home.hero.photo %}
      <div class="hero__photo">
        <img src="{{ home.hero.photo | url }}" alt="{{ home.hero.photo_alt }}" loading="eager" />
      </div>
      {% endif %}
    </div>
  </div>
</section>

<section id="about" class="about">
  <div class="container">
    <div class="about__grid">
      {% if home.about_teaser.photo %}
      <div class="about__photo">
        <img src="{{ home.about_teaser.photo | url }}" alt="{{ home.about_teaser.photo_alt }}" loading="lazy" />
      </div>
      {% endif %}
      <div class="about__body">
        <h2 class="about__heading">{{ home.about_teaser.heading }}</h2>
        <div class="lead">{{ home.about_teaser.lede | mdBody | safe }}</div>
        {{ home.about_teaser.body | mdBody | safe }}
        {% if home.about_teaser.link_text %}
        <p><a href="{{ home.about_teaser.link_target | url }}">{{ home.about_teaser.link_text }}</a></p>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<section id="priorities">
  <div class="container">
    <h2 class="priorities__heading">{{ home.priorities_section.heading }}</h2>
    <div class="priorities__lede">{{ home.priorities_section.lede | mdBody | safe }}</div>
    <div class="priorities__grid">
      {%- for slug in home.priorities_section.priorities %}
        {%- set p = policies[slug] %}
        {%- if p %}
        <article class="priority-card">
          <span class="priority-card__number">{{ "0" + (loop.index | string) }} / {{ p.label }}</span>
          <h3 class="priority-card__heading">{{ p.heading }}</h3>
          <div class="priority-card__body">{{ p.body | mdBody | safe }}</div>
        </article>
        {%- endif %}
      {%- endfor %}
    </div>
  </div>
</section>

{%- set focus = policies[site.in_focus_policy] %}
{%- if focus %}
<section id="in-focus" class="in-focus">
  <div class="container">
    <p class="in-focus__eyebrow">{{ home.in_focus.eyebrow }}</p>
    <div class="in-focus__grid">
      <div class="in-focus__stat-block">
        {%- if focus.stat_value %}
        {%- if focus.stat_lead %}
        <p class="in-focus__stat-lead">{{ focus.stat_lead | mdInline | safe }}</p>
        {%- endif %}
        <p class="in-focus__stat-figure">{{ focus.stat_value }}</p>
        {%- if focus.stat_trail %}
        <p class="in-focus__stat-trail">{{ focus.stat_trail | mdInline | safe }}</p>
        {%- endif %}
        {%- if focus.stat_source %}
        <p class="in-focus__stat-source">— {{ focus.stat_source }}</p>
        {%- endif %}
        {%- endif %}
      </div>
      <div class="in-focus__body">
        <h2 class="in-focus__heading">{{ focus.heading }}</h2>
        {{ focus.body | mdBody | safe }}
        {%- if focus.cta_target %}
        <a class="in-focus__cta" href="{{ focus.cta_target | url }}">{{ focus.cta_label }}</a>
        {%- endif %}
      </div>
    </div>
  </div>
</section>
{%- endif %}

<section id="get-involved">
  <div class="container">
    <h2 class="get-involved__heading">{{ home.get_involved.heading }}</h2>
    <div class="get-involved__grid">

      <div class="cta-card cta-card--primary">
        <h3 class="cta-card__heading">{{ home.get_involved.donate_card.heading }}</h3>
        <div class="cta-card__body">{{ home.get_involved.donate_card.body | mdBody | safe }}</div>
        {% if home.get_involved.donate_card.enabled and home.get_involved.donate_card.actblue_url %}
        {%- set abu = home.get_involved.donate_card.actblue_url %}
        <div class="donate-amounts" role="group" aria-label="Suggested donation amounts">
          <a class="donate-amount" href="{{ abu }}?amount=25&refcode=home-25" target="_blank" rel="noopener">$25</a>
          <a class="donate-amount" href="{{ abu }}?amount=50&refcode=home-50" target="_blank" rel="noopener">$50</a>
          <a class="donate-amount" href="{{ abu }}?amount=100&refcode=home-100" target="_blank" rel="noopener">$100</a>
          <a class="donate-amount" href="{{ abu }}?amount=250&refcode=home-250" target="_blank" rel="noopener">$250</a>
          <a class="donate-amount" href="{{ abu }}?amount=500&refcode=home-500" target="_blank" rel="noopener">$500</a>
          <a class="donate-amount" href="{{ abu }}?refcode=home-other" target="_blank" rel="noopener">Other</a>
        </div>
        {% else %}
        <span class="cta-card__pending">{{ home.get_involved.donate_card.pending_label }}</span>
        {% endif %}
      </div>

      <div class="cta-card">
        <h3 class="cta-card__heading">{{ home.get_involved.email_card.heading }}</h3>
        <div class="cta-card__body">{{ home.get_involved.email_card.body | mdBody | safe }}</div>
        {# Progressive-ask pattern. Submit GETs /signup with the
           email in the query string; /signup hosts the AN widget
           and prefills it from the URL via JS. Keeps the visitor
           on our domain through the whole flow. #}
        <form action="{{ '/signup' | url }}" method="get" aria-label="Email signup">
          <label class="sr-only" for="email">Email address</label>
          <input id="email" name="email_address" type="email" placeholder="you@example.com" required autocomplete="email" />
          <button type="submit">{{ home.get_involved.email_card.submit_label }}</button>
        </form>
      </div>

      <div class="cta-card">
        <h3 class="cta-card__heading">{{ home.get_involved.volunteer_card.heading }}</h3>
        <div class="cta-card__body">{{ home.get_involved.volunteer_card.body | mdBody | safe }}</div>
        <a class="button button--secondary" href="{{ '/volunteer' | url }}">{{ home.get_involved.volunteer_card.cta_label }}</a>
      </div>

    </div>
  </div>
</section>
