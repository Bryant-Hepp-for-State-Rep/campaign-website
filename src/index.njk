---
layout: layouts/base.njk
title: Bryant Hepp for State Rep — Home
description: Bryant Hepp, Democrat for Michigan State House District 9.
permalink: /index.html
---

<section class="hero">
  <div class="container">
    <div class="hero__grid">
      <div>
        <span class="hero__office">{{ home.hero.eyebrow }}</span>
        <h1 class="hero__name">{{ home.hero.name }}</h1>
        <p class="hero__district">{{ home.hero.district_line }}</p>
        <p class="hero__tagline">{{ home.hero.tagline }}</p>
        <p class="hero__subhead">{{ home.hero.subhead | mdInline | safe }}</p>
        <div class="hero__ctas">
          <a class="button button--primary" href="{{ home.hero.primary_cta.target | url }}">{{ home.hero.primary_cta.label }}</a>
          {% if home.hero.secondary_cta and home.hero.secondary_cta.label %}
          <a class="button button--secondary" href="{{ home.hero.secondary_cta.target | url }}">{{ home.hero.secondary_cta.label }}</a>
          {% endif %}
        </div>
      </div>
      <div class="hero__photo" aria-hidden="true">
        <span class="hero__photo-label">[ Photo placeholder — community / candid ]</span>
      </div>
    </div>
  </div>
</section>

<section id="about" class="about">
  <div class="container">
    <div class="about__grid">
      <div class="about__photo" aria-hidden="true">[ Photo placeholder ]</div>
      <div class="about__body">
        <h2 class="about__heading">{{ home.about_teaser.heading }}</h2>
        <div class="lead">{{ home.about_teaser.lede | mdBody | safe }}</div>
        {{ home.about_teaser.body | mdBody | safe }}
        {% if home.about_teaser.link_text %}
        <p><a href="{{ home.about_teaser.link_target | url }}">{{ home.about_teaser.link_text }}</a></p>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{%- set focus = policies[site.in_focus_policy] %}
{%- if focus %}
<section id="in-focus" class="in-focus">
  <div class="container">
    <p class="in-focus__eyebrow">{{ home.in_focus.eyebrow }}</p>
    <div class="in-focus__grid">
      <div>
        {%- if focus.stat_value %}
        <div class="in-focus__stat">{{ focus.stat_value }}</div>
        <p class="in-focus__stat-label">{{ focus.stat_label | mdInline | safe }}</p>
        {%- endif %}
      </div>
      <div class="in-focus__body">
        <h2 class="in-focus__heading">{{ focus.heading }}</h2>
        {{ focus.body | mdBody | safe }}
        {%- if focus.cta_target %}
        <a class="in-focus__cta" href="{{ focus.cta_target | url }}">{{ focus.cta_label }}</a>
        {%- endif %}
        <p class="in-focus__see-all"><a href="{{ '/policies/' | url }}">{{ home.in_focus.see_all_label }}</a></p>
      </div>
    </div>
  </div>
</section>
{%- endif %}

<section id="get-involved">
  <div class="container">
    <h2 class="get-involved__heading">{{ home.get_involved.heading }}</h2>
    <div class="get-involved__grid">

      <div class="cta-card cta-card--primary">
        <h3 class="cta-card__heading">{{ home.get_involved.email_card.heading }}</h3>
        <div class="cta-card__body">{{ home.get_involved.email_card.body | mdBody | safe }}</div>
        <form action="{{ home.get_involved.email_card.form_action }}" method="post" aria-label="Email signup">
          <label class="sr-only" for="email">Email address</label>
          <input id="email" name="email" type="email" placeholder="you@example.com" required />
          <button type="submit">{{ home.get_involved.email_card.submit_label }}</button>
        </form>
      </div>

      <div class="cta-card">
        <h3 class="cta-card__heading">{{ home.get_involved.volunteer_card.heading }}</h3>
        <div class="cta-card__body">{{ home.get_involved.volunteer_card.body | mdBody | safe }}</div>
        <a class="button button--secondary" href="mailto:{{ site.contact_email }}?subject={{ home.get_involved.volunteer_card.email_subject | urlencode }}">{{ home.get_involved.volunteer_card.cta_label }}</a>
      </div>

      <div class="cta-card">
        <h3 class="cta-card__heading">{{ home.get_involved.donate_card.heading }}</h3>
        <div class="cta-card__body">{{ home.get_involved.donate_card.body | mdBody | safe }}</div>
        {% if home.get_involved.donate_card.enabled and home.get_involved.donate_card.actblue_url %}
        <a class="button button--primary" href="{{ home.get_involved.donate_card.actblue_url | url }}" target="_blank" rel="noopener">Donate</a>
        {% else %}
        <span class="cta-card__pending">{{ home.get_involved.donate_card.pending_label }}</span>
        {% endif %}
      </div>

    </div>
  </div>
</section>
