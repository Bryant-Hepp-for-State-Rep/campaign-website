---
layout: layouts/base.njk
title: About Bryant Hepp
description: About Bryant Hepp — candidate for Michigan State House District 9.
permalink: /about/index.html
---

<style>
  .bio-hero {
    padding-block: clamp(3rem, 7vw, 5rem) clamp(2rem, 4vw, 3rem);
  }
  .bio-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  @media (max-width: 880px) {
    .bio-hero__grid { grid-template-columns: 1fr; }
  }
  .bio-hero__photo {
    aspect-ratio: 4 / 5;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    font-style: italic;
  }
  .bio-hero__eyebrow {
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-eyebrow);
    margin-bottom: 0.75rem;
  }
  .bio-hero__name {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin-bottom: 0.5rem;
  }
  .bio-hero__role {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    margin-bottom: 1.75rem;
  }
  .bio-hero__lede {
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
    line-height: 1.55;
    max-width: 50ch;
  }
  .bio-section {
    padding-block: clamp(2.5rem, 5vw, 4rem);
    border-top: 1px solid var(--color-border);
  }
  .bio-section__heading {
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-eyebrow);
    margin-bottom: 1.5rem;
  }
  .bio-section h3 { font-size: 1.4rem; margin-bottom: 1rem; }
  .bio-section p { font-size: 1.05rem; line-height: 1.6; margin-bottom: 1rem; max-width: 60ch; }
  .bio-list { list-style: none; padding: 0; margin: 0 0 1rem 0; max-width: 60ch; }
  .bio-list li {
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: 6em 1fr;
    gap: 1rem;
    align-items: baseline;
  }
  .bio-list strong { color: var(--color-text-muted); font-weight: 700; font-size: 0.9rem; }
</style>

<section class="bio-hero">
  <div class="container">
    <div class="bio-hero__grid">
      <div class="bio-hero__photo" aria-hidden="true">[ Portrait placeholder ]</div>
      <div>
        <p class="bio-hero__eyebrow">{{ about.hero.eyebrow }}</p>
        <h1 class="bio-hero__name">{{ about.hero.name }}</h1>
        <p class="bio-hero__role">{{ about.hero.role }}</p>
        <div class="bio-hero__lede">{{ about.hero.lede | mdBody | safe }}</div>
      </div>
    </div>
  </div>
</section>

{%- for section in about.bio_sections %}
<section class="bio-section">
  <div class="container">
    <h2 class="bio-section__heading">{{ section.eyebrow }}</h2>
    {%- if section.type == "prose" %}
      {{ section.body | mdBody | safe }}
    {%- elif section.type == "list" %}
    <ul class="bio-list">
      {%- for item in section.items %}
      <li><strong>{{ item.label }}</strong><span>{{ item.text | mdInline | safe }}</span></li>
      {%- endfor %}
    </ul>
    {%- endif %}
  </div>
</section>
{%- endfor %}
