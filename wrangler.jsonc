{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hepp4rep",
  "compatibility_date": "2026-05-06",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "_site"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    { "pattern": "hepp4rep.com", "custom_domain": true },
    { "pattern": "www.hepp4rep.com", "custom_domain": true }
  ]
}
